# ===== 数据库 =====
# 生产环境通过 PgBouncer 连接 (端口 6432), 直连 PG 用 5432
DATABASE_URL=postgresql+asyncpg://ai_town:password@localhost:5432/ai_town
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# pgvector
EMBEDDING_DIM=1536

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== LLM 配置 =====
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_CHAT=gpt-4o-mini
MODEL_STRONG=gpt-4o
MODEL_FLASH=gpt-3.5-turbo
MODEL_EMBEDDING=text-embedding-3-small
# Embedding 模型独立 API Key/URL（如使用 OpenRouter 等多模态服务）
EMBEDDING_MODEL_KEY=
EMBEDDING_MODEL_URL=
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2

# ===== MCP Servers =====
# 已移除 code-executor 和 web-search（外部能力，非内部业务所需）
MCP_WEATHER_SERVER=http://localhost:8003
MCP_SHOP_SERVER=http://localhost:8004
MCP_KB_SERVER=http://localhost:8005
MCP_SOCIAL_SERVER=http://localhost:8006
MCP_TOOL_TIMEOUT=30

# ===== 可观测性 =====
OTEL_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ai-town-backend
OTEL_TRACES_SAMPLER_RATE=0.5
LANGFUSE_PUBLIC_KEY=pk-xxx
LANGFUSE_SECRET_KEY=sk-xxx
LANGFUSE_HOST=http://localhost:3001
LOKI_URL=http://loki:3100
LOG_LEVEL=info
LOG_FORMAT=json

# ===== 消息平台 =====
ONEBOT_DEFAULT_CHARACTER_ID=
# 机器人自身 QQ 号（可选，也可从 OneBot 事件 self_id 获取）
ONEBOT_SELF_ID=
# 群聊是否仅在被 @ 时回复（默认 false：读取所有群消息并智能决策）
ONEBOT_GROUP_AT_ONLY=false
# 群组-角色映射：JSON 字符串 {"群号": "角色UUID"}，未配置的群使用默认角色
ONEBOT_GROUP_CHARACTER_MAP={}

# ===== 鉴权 =====
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
API_KEY=your-api-key
# RBAC 角色配置（逗号分隔的用户名:角色列表，角色可选 admin/operator/viewer）
# 示例：admin:admin,viewer1:viewer,operator1:operator
RBAC_ROLES=

# ===== 管理员账号 =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ===== 成本控制 =====
LLM_DAILY_BUDGET_USD=10.0
LLM_CIRCUIT_BREAKER_THRESHOLD=5
LLM_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# ===== 记忆系统 =====
# 是否启用 LLM 评分（对事件 1-10 分评估重要性，默认关闭使用规则评分）
MEMORY_LLM_SCORING_ENABLED=false

# ===== 世界引擎 =====
# World Tick 间隔（秒）：每隔多少秒执行一次世界推进
WORLD_TICK_SECONDS=30
# 每次 Tick 推进多少分钟虚拟时间（支持小数）
# 时间流速 = WORLD_TICK_MINUTES / WORLD_TICK_SECONDS（虚拟分钟/现实秒）
# 默认 10/30 = 0.33 → 1现实秒 = 20虚拟分钟（20倍速）
# 1:1现实同步：WORLD_TICK_SECONDS=60, WORLD_TICK_MINUTES=1.0
# 2倍速：WORLD_TICK_SECONDS=30, WORLD_TICK_MINUTES=1.0
# 10倍速：WORLD_TICK_SECONDS=30, WORLD_TICK_MINUTES=5.0
WORLD_TICK_MINUTES=10
# 虚拟世界初始时间（ISO 格式，如 "2026-07-01T08:00:00"）；留空则使用当前现实日期 08:00
WORLD_INITIAL_TIME=
WORLD_WEATHER_INTERVAL=60
# 每 N Tick 持久化差分事件到 world_events
WORLD_SNAPSHOT_INTERVAL=10
# 每 N Tick 存一次完整快照到 world_snapshots（冷启动恢复）
WORLD_FULL_SNAPSHOT_INTERVAL=1000
CHARACTER_TICK_SECONDS=30
CHARACTER_MAX_CONCURRENT=10
CHARACTER_LOCK_TTL_SECONDS=30

# ===== 主动分享配置 =====
SHARE_COOLDOWN_SECONDS=1800
SHARE_DAILY_LIMIT=8
SHARE_PROBABILITY_ACTION=0.6
SHARE_PROBABILITY_MOOD=0.5
SHARE_PROBABILITY_LOCATION=0.2
SHARE_PROBABILITY_ROUTINE=0.15
